# =====================================================================
# Unreal Engine plugin ignore file · Vessel
# =====================================================================

# ---------- UE build outputs ----------
Binaries/
Build/
DerivedDataCache/
Intermediate/
Saved/

# ---------- IDE / editor ----------
.vs/
*.suo
*.sdf
*.opensdf
*.VC.db
*.VC.opendb
*.pdb
.idea/
*.iml
*.DotSettings.user
*.swp
*.swo
.vscode/

# ---------- Generated project files ----------
*.sln
*.xcworkspace/
*.xcodeproj/

# ---------- OS cruft ----------
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
desktop.ini
ehthumbs.db
$RECYCLE.BIN/

# ---------- Logs ----------
*.log
*.log.*
crashreporter.log

# =====================================================================
# Vessel-specific
# =====================================================================

# Per-user settings file — may contain API keys. NEVER commit.
# See BUILD.md §2 and AGENTS.md safety rules.
**/VesselUserSettings.ini
**/EditorPerProjectUserSettings.ini

# Session artifacts (logs can be large; keep local unless explicitly shared)
Saved/AgentSessions/
Saved/VesselReports/
Saved/VesselMetrics/
Saved/VesselRejectionArchive/

# =====================================================================
# Secrets
# =====================================================================
.env
.env.*
*.secret
secrets/

# =====================================================================
# Python (optional v0.2+ extension module)
# =====================================================================
__pycache__/
*.py[codz]
*.egg-info/

# =====================================================================
# Node (only if contributors add docs tooling)
# =====================================================================
node_modules/
.npm
